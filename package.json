{
  "name": "ag-theme",
  "version": "1.0.0",
  "description": "Drupal Mercury child theme frontend build tools.",
  "private": true,
  "scripts": {
    "build:css": "sass scss/theme.scss css/style.css --style=expanded --source-map && postcss css/style.css --replace",
    "build:css:min": "sass scss/theme.scss css/style.min.css --style=compressed --no-source-map && postcss css/style.min.css --replace",
    "watch:css": "sass scss/theme.scss css/style.css --style=expanded --source-map --watch",
    "postcss": "postcss css/style.css --replace"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "sass": "^1.69.0"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  }
}
